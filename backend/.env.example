# Sunucuda backend/.env olarak kopyalayın (dotenv otomatik yükler).
# Kullanıcılar, aktivite logları ve günlük ürün bilgisi tek SQLite dosyasında tutulur.

# Kalıcı dizin (önerilen VPS yolu — klasörü oluşturup chown edin):
# TEKSTIL_DATA_DIR=/var/lib/tekstil-uretim

# Veya dosyanın tam yolu:
# SQLITE_DATABASE_PATH=/var/lib/tekstil-uretim/production.db

# İlk kurulum admin (yalnızca users tablosu boşken eklenir):
# APP_USERNAME=admin
# APP_PASSWORD=güçlü-bir-şifre
# APP_TOKEN_SECRET=en-az-32-karakter-rastgele
