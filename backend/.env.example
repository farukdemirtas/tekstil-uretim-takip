# Sunucuda kopyalayın: cp backend/.env.example backend/.env
# Gerçek şifreleri yalnızca backend/.env dosyasına yazın — bu dosya git'e girmez.

PORT=4000

# Kalıcı dizin (önerilen VPS yolu):
# TEKSTIL_DATA_DIR=/var/lib/tekstil-uretim
# SQLITE_DATABASE_PATH=/var/lib/tekstil-uretim/production.db

# Uygulama oturumu (üretimde mutlaka değiştirin):
# APP_USERNAME=admin
# APP_PASSWORD=degistirin-guclu-sifre
# APP_TOKEN_SECRET=en-az-32-karakter-rastgele-uretin

# Takipsan Plus → Ütü–Paket köprüsü
TAKIPSAN_ENABLED=true
TAKIPSAN_BASE_URL=https://takipsan.takipsanplus.com
TAKIPSAN_USERNAME=
# Özel karakter varsa tırnak içine alın: TAKIPSAN_PASSWORD="*Sifre123*"
TAKIPSAN_PASSWORD=
TAKIPSAN_CONSIGNMENT_ID=
TAKIPSAN_SYNC_INTERVAL_MS=30000
