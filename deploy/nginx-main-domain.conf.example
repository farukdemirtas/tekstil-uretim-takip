# Ana domain veya üretim takip için: depo ile KARIŞTIRMAYIN.
# Depo yalnızca depo.yesilimajtekstil.com gibi AYRI server_name ile kalmalı.
#
# Bu dosyayı örnek alarak /etc/nginx/sites-available/yesilimajtekstil (veya tekstil)
# içeriğini düzenleyin: `root .../depo-takip` veya yanlış proxy OLMAMALI.
#
# PM2: tekstil-web → 3000, tekstil-api → 4000 (depo başka port kullanmalı veya ayrı sunucu)
#
# Kurulum:
#   sudo nano /etc/nginx/sites-available/yesilimajtekstil
#   (aşağıdaki server bloğunu mevcut 80 bloğuyla uyumlu hale getirin; SSL varsa 443 bloğunda da aynı location'lar)
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d yesilimajtekstil.com -d www.yesilimajtekstil.com

server {
    listen 80;
    listen [::]:80;
    server_name yesilimajtekstil.com www.yesilimajtekstil.com;

    location /api/ {
        proxy_pass http://127.0.0.1:4000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
