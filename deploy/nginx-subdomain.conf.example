# Üretim takip (Next.js) için subdomain örneği.
# Depo takip ile aynı sunucuda: depo site dosyasında `root .../depo-takip` kalır;
# bu dosyada ise SADECE proxy_pass (3000 / 4000) kullanın — depo root buraya yazılmaz.
#
# /etc/nginx/sites-available/tekstil içine kopyalayın.
# Alan adı: takip.yesilimajtekstil.com
# Sonra: sudo ln -sf /etc/nginx/sites-available/tekstil /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx
# sudo certbot --nginx -d takip.yesilimajtekstil.com

server {
    listen 80;
    server_name takip.yesilimajtekstil.com;

    location /api/ {
        client_max_body_size 160m;
        proxy_pass http://127.0.0.1:4000/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
